# SPDX-License-Identifier: GPL-3.0-or-later
# Maintainer:   Knot Resolver team <knot-resolver@labs.nic.cz>

pkgname=knot-resolver
pkgver={{ version }}
pkgrel={{ release }}
pkgdesc='Caching DNSSEC-validating DNS resolver'
arch=('x86_64' 'armv7h')
url='https://www.knot-resolver.cz/'
license=('GPL-3.0-or-later')

depends=(
    'dnssec-anchors'
    'gnutls'
    'knot'
    'libuv'
    'lmdb'
    'luajit'
    'systemd'
    'libcap-ng'
    'libnghttp2'
    'jemalloc'
    'python'
    'python-yaml'
    'python-aiohttp'
    'python-typing_extensions'
    'python-jinja'
    'supervisor'
)

optdepends=(
    'lua51-basexx: experimental_dot_auth module'
    'lua51-cqueues: http and dns64 module, policy.rpz() function'
    'lua51-http: http and prefill modules, trust_anchors bootstrap'
    'lua51-psl: policy.slice_randomize_psl() function'
    'python-prometheus_client: stats and metrics in Prometheus format'
    'python-watchdog: files monitoring and reload on changes'
)

makedepends=(
    'cmocka'
    'meson'
    'ninja'
    'pkgconf'
    'python-build'
    'python-installer'
    'python-poetry-core'
    'python-wheel'
)

backup=('etc/knot-resolver/config.yaml')

options=(debug)

source=("knot-resolver-${pkgver}.tar.xz")
sha256sums=('SKIP')

build() {
    local meson_options=(
        --buildtype=plain
        --prefix=/usr
        --sbindir=bin

        -Dkeyfile_default=/etc/trusted-key.key
        -Dsystemd_files=enabled
        -Dmalloc=jemalloc
        -Dunit_tests=enabled
    )

    arch-meson "${srcdir}/${pkgname}-${pkgver}" \
        build "${meson_options[@]}"
    meson compile -C build

    # Build Python wheel
    python -m build --wheel --no-isolation \
        "${srcdir}/${pkgname}-${pkgver}"
}

check() {
    meson test -C build --print-errorlogs
}

package() {
    meson install -C build --destdir "${pkgdir}"

    # Install Python wheel into pkgdir
    python -m installer \
        --destdir="${pkgdir}" \
        ${srcdir}/${pkgname}-${pkgver}/dist/*.whl

    # Default configuration
    install -Dm644 \
        "${srcdir}/${pkgname}-${pkgver}/etc/config/config.yaml" \
        "${pkgdir}/etc/knot-resolver/config.yaml"

    # Remove optional module requiring unavailable deps
    rm -f "${pkgdir}/usr/lib/knot-resolver/kres_modules/etcd.lua"
}
